{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-7",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "Skill(*)",
      "WebFetch",
      "WebSearch",

      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(make:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(uv:*)",
      "Bash(uvx:*)",
      "Bash(pytest:*)",
      "Bash(cargo:*)",
      "Bash(go:*)",
      "Bash(docker compose:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",

      "mcp__*"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:--force*)",
      "Bash(git push:-f*)",
      "Bash(git reset:--hard*)",
      "Bash(git clean:-f*)",
      "Bash(git branch:-D*)",
      "Bash(docker system prune:*)",
      "Bash(kubectl delete:*)",
      "Bash(terraform destroy:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [{ "type": "command", "command": ".claude/hooks/protect-sensitive-files.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/auto-format-python.sh" },
          { "type": "command", "command": ".claude/hooks/auto-format-javascript.sh" },
          { "type": "command", "command": ".claude/hooks/auto-format-markdown.sh" },
          { "type": "command", "command": ".claude/hooks/auto-format-yaml.sh" },
          { "type": "command", "command": ".claude/hooks/auto-format-go.sh" },
          { "type": "command", "command": ".claude/hooks/auto-format-rust.sh" }
        ]
      }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": ".claude/hooks/stop-lint-check.sh" }] }
    ],
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": ".claude/hooks/session-start.sh" }] }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  },
  "enableAllProjectMcpServers": true
}
