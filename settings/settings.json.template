{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "//model": "Default model for this project. Examples: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001",
  "model": "claude-sonnet-4-6",

  "//permissions": "Allow patterns match `ToolName(arg-pattern)`. Deny takes precedence. Start narrow; widen as workflows demand.",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "Skill(*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git push:-u origin *)",

      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh api:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:--force*)",
      "Bash(git push:-f*)",
      "Bash(git reset:--hard*)"
    ]
  },

  "//hooks": "Wire scripts from .claude/hooks/ to events. Every hook file needs an entry here or it never runs.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [{ "type": "command", "command": ".claude/hooks/protect-sensitive-files.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/auto-format-python.sh" },
          { "type": "command", "command": ".claude/hooks/auto-format-javascript.sh" },
          { "type": "command", "command": ".claude/hooks/auto-format-markdown.sh" },
          { "type": "command", "command": ".claude/hooks/auto-format-yaml.sh" }
        ]
      }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": ".claude/hooks/stop-lint-check.sh" }] }
    ],
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": ".claude/hooks/session-start.sh" }] }
    ]
  },

  "//statusLine": "Path to the statusline script. Omit this block to use Claude Code's default.",
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  },

  "//enableAllProjectMcpServers": "Set true to let Claude Code launch every server under .claude/mcp/. False = opt in per-server.",
  "enableAllProjectMcpServers": false
}
